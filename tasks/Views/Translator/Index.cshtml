@model tasks.Models.TranslatorViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card shadow-lg p-4">
                <h2 class="text-center mb-4">🌍 Azure Translator</h2>

                <form asp-action="Translate" method="post">

                    <div class="row mb-3">
                        <div class="col">
                            <label class="form-label">Мова оригіналу</label>
                            <select asp-for="SourceLanguage" class="form-select">
                                <option value="uk">Українська</option>
                                <option value="en">English</option>
                                <option value="de">Deutsch</option>
                            </select>
                        </div>

                        <div class="col">
                            <label class="form-label">Мова перекладу</label>
                            <select asp-for="TargetLanguage" class="form-select">
                                <option value="en">English</option>
                                <option value="uk">Українська</option>
                                <option value="de">Deutsch</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Введіть текст</label>
                        <textarea asp-for="Text" class="form-control" rows="5"></textarea>
                    </div>

                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-primary btn-lg">
                            🔄 Перекласти
                        </button>
                    </div>

                    @if (Model.TranslatedText != null)
                    {
                        <div class="mb-3">
                            <label class="form-label">Результат</label>
                            <textarea class="form-control" rows="5" readonly>
@Model.TranslatedText
                            </textarea>
                        </div>
                    }

                </form>

            </div>

        </div>
    </div>
</div>
